generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── AUTH ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(VIEWER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  deliverables     Deliverable[]    @relation("DeliverableAssignees")
  productionCards  ProductionCard[] @relation("ProductionAssignee")
  editTasksClaimed EditTask[]       @relation("EditTaskClaimed")
  comments         Comment[]
  activities       ActivityLog[]
  notifications    Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── DELIVERABLE (Source of Truth) ────────────────────────────────────────────

model Deliverable {
  id          String            @id @default(cuid())
  pnNo        String            @unique
  title       String
  brand       String
  platforms   Platform[]
  type        DeliverableType   @default(YOUTUBE_VIDEO)
  status      DeliverableStatus @default(DRAFT)
  priority    Priority          @default(MEDIUM)
  deadline    DateTime?
  publishDate DateTime?

  // Financial
  invoiceNumber String?
  emailSent     Boolean @default(false)
  advance50     Boolean @default(false)
  payment100    Boolean @default(false)

  // Content
  script      String? @db.Text
  notes       String? @db.Text
  hook        String?
  description String? @db.Text

  // Links
  footageFolder String?
  thumbnailLink String?
  exportLink    String?
  publishedUrl  String?

  // Publishing metadata
  publishTitle String?
  publishDesc  String? @db.Text
  publishTags  String[]

  // POC
  pocName    String?
  pocEmail   String?
  pocCompany String?

  // Obsidian
  obsidianPath     String?
  obsidianSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTo    User[]          @relation("DeliverableAssignees")
  production    ProductionCard?
  editTask      EditTask?
  thumbnailTask ThumbnailTask?
  publishTask   PublishTask?
  versions      ExportVersion[]
  revisions     Revision[]
  comments      Comment[]
  activities    ActivityLog[]
}

// ─── WORKFLOW STAGES ──────────────────────────────────────────────────────────

model ProductionCard {
  id             String           @id @default(cuid())
  deliverableId  String           @unique
  deliverable    Deliverable      @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  status         ProductionStatus @default(READY_TO_SHOOT)
  assignedUserId String?
  assignedTo     User?            @relation("ProductionAssignee", fields: [assignedUserId], references: [id])

  location      String?
  equipment     String[]
  shootStartAt  DateTime?
  shootEndAt    DateTime?
  pausedAt      DateTime?
  totalDuration Int?

  isDelayed   Boolean @default(false)
  delayReason String?

  footageUploaded Boolean @default(false)
  footageLink     String?
  backupConfirmed Boolean @default(false)
  folderName      String?

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EditTask {
  id              String     @id @default(cuid())
  deliverableId   String     @unique
  deliverable     Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  status          EditStatus  @default(READY_FOR_EDIT)
  claimedByUserId String?
  claimedBy       User?       @relation("EditTaskClaimed", fields: [claimedByUserId], references: [id])
  claimedAt       DateTime?

  editStartAt   DateTime?
  editEndAt     DateTime?
  totalEditTime Int?

  revisionCount Int     @default(0)
  footageFolder String?
  footageNotes  String? @db.Text
  notes         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  versions ExportVersion[]
}

model ThumbnailTask {
  id             String          @id @default(cuid())
  deliverableId  String          @unique
  deliverable    Deliverable     @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  status         ThumbnailStatus @default(PENDING)
  assignedUserId String?

  titleOptions  String[]
  selectedTitle String?
  thumbnailUrl  String?
  approvedAt    DateTime?

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublishTask {
  id             String        @id @default(cuid())
  deliverableId  String        @unique
  deliverable    Deliverable   @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  status         PublishStatus @default(PENDING)
  assignedUserId String?

  scheduledFor DateTime?
  publishedAt  DateTime?
  publishedUrl String?
  platforms    Platform[]

  thumbnailReady   Boolean @default(false)
  descriptionReady Boolean @default(false)
  tagsReady        Boolean @default(false)
  cardReady        Boolean @default(false)
  captionsReady    Boolean @default(false)

  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── VERSIONING ───────────────────────────────────────────────────────────────

model ExportVersion {
  id            String       @id @default(cuid())
  editTaskId    String
  editTask      EditTask     @relation(fields: [editTaskId], references: [id], onDelete: Cascade)
  deliverableId String
  deliverable   Deliverable  @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  label         VersionLabel
  url           String
  notes         String?      @db.Text
  uploadedBy    String?
  approved      Boolean      @default(false)
  approvedAt    DateTime?
  createdAt     DateTime     @default(now())
}

model Revision {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  requestedBy   String?
  description   String      @db.Text
  isResolved    Boolean     @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime    @default(now())
}

// ─── KANBAN ───────────────────────────────────────────────────────────────────

model KanbanBoard {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  color       String   @default("#7c3aed")
  emoji       String   @default("🎬")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  columns KanbanColumn[]
}

model KanbanColumn {
  id      String      @id @default(cuid())
  boardId String
  board   KanbanBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)
  title   String
  order   Int         @default(0)

  cards KanbanCard[]
}

model KanbanCard {
  id              String       @id @default(cuid())
  columnId        String
  column          KanbanColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  boardId         String
  title           String
  description     String       @default("") @db.Text
  deliverableType String?
  thumbnailUrl    String?
  videoLink       String?
  tags            Json         @default("[]")
  priority        String       @default("medium")
  dueDate         String?
  notes           String       @default("") @db.Text
  order           Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

// ─── COLLABORATION ────────────────────────────────────────────────────────────

model Comment {
  id            String      @id @default(cuid())
  deliverableId String
  deliverable   Deliverable @relation(fields: [deliverableId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  body          String      @db.Text
  parentId      String?
  parent        Comment?    @relation("CommentThread", fields: [parentId], references: [id])
  replies       Comment[]   @relation("CommentThread")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model ActivityLog {
  id            String       @id @default(cuid())
  deliverableId String?
  deliverable   Deliverable? @relation(fields: [deliverableId], references: [id])
  userId        String
  user          User         @relation(fields: [userId], references: [id])
  action        String
  meta          Json?
  createdAt     DateTime     @default(now())
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id])
  type      NotificationType
  title     String
  body      String?
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
}

// ─── ENUMS ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PRODUCTION_LEAD
  EDITOR
  THUMBNAIL_DESIGNER
  PUBLISHER
  WRITER
  FINANCE
  VIEWER
}

enum Platform {
  YOUTUBE
  INSTAGRAM
  TIKTOK
  PODCAST
  TWITTER
  LINKEDIN
  COMMUNITY
}

enum DeliverableType {
  REEL
  SHORT
  YOUTUBE_VIDEO
  PODCAST
  BRAND_INTEGRATION
  PRODUCT_REVIEW
  EVENT_COVERAGE
  COMPARISON_VIDEO
  THUMBNAIL_ONLY
  COMMUNITY_POST
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DeliverableStatus {
  DRAFT
  ACTIVE
  IN_PRODUCTION
  IN_EDIT
  IN_REVIEW
  REVISION_REQUESTED
  APPROVED
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum ProductionStatus {
  READY_TO_SHOOT
  EQUIPMENT_READY
  SHOOTING
  BACKUP_PENDING
  FOOTAGE_UPLOADED
  AWAITING_EDIT
  DELAYED
  COMPLETED
}

enum EditStatus {
  READY_FOR_EDIT
  CLAIMED
  ROUGH_CUT
  INTERNAL_REVIEW
  REVISIONS
  FINAL_EXPORT
  UPLOAD_READY
  ARCHIVED
}

enum ThumbnailStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  APPROVED
  REJECTED
}

enum PublishStatus {
  PENDING
  SCHEDULED
  PUBLISHED
  FAILED
}

enum VersionLabel {
  DRAFT_1
  DRAFT_2
  CLIENT_REVISION
  FINAL_APPROVED
  PUBLISHED_EXPORT
}

enum NotificationType {
  DEADLINE_MISSED
  DEADLINE_APPROACHING
  PRODUCTION_DELAYED
  EDIT_CLAIMED
  REVIEW_REQUESTED
  UPLOAD_SCHEDULED
  PUBLISH_REMINDER
  COMMENT_ADDED
  REVISION_REQUESTED
  TASK_ASSIGNED
}
